#!/usr/bin/env bash
# Pre-commit hook: compile-check any staged .py files so syntax and
# indentation errors never leave your machine.
#
# Enable once per clone with:
#     git config core.hooksPath .githooks

set -e

py_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

if [ -z "$py_files" ]; then
  exit 0
fi

echo "→ compile-checking: $py_files"
# shellcheck disable=SC2086
python3 -m py_compile $py_files

echo "✓ pre-commit: python syntax OK"
