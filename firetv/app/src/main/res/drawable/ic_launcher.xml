<?xml version="1.0" encoding="utf-8"?>
<!--
  App icon — combined background + foreground in a single vector
  drawable so it renders correctly on every API ≥ 22.

  Stylized DineroBook "$" mark in neon green on near-black.
  Replace with a hi-res PNG at app/src/main/res/mipmap-* before
  Amazon submission for a more polished store-listing icon —
  Amazon's listing also takes a separate 512×512 small-icon PNG
  (see firetv/README.md "Amazon submission").
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Near-black square background (rounded corners are applied
         by the launcher tile). -->
    <path
        android:fillColor="#0a0a0a"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />

    <!-- "$" glyph: top vertical, bottom vertical, S-curve body.
         Neon green stroke at 6 units, rounded caps. -->
    <path
        android:strokeColor="#3fff00"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M54,28 L54,38 M54,70 L54,80 M68,42 C68,36 62,32 54,32 C46,32 40,36 40,42 C40,48 46,50 54,52 C62,54 68,56 68,62 C68,68 62,72 54,72 C46,72 40,68 40,62" />
</vector>
