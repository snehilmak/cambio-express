<?xml version="1.0" encoding="utf-8"?>
<!--
  Primary CTA button. Neon green when enabled / focused, dimmed
  surface gray when the input isn't yet 6 chars. Focus state
  brightens for D-pad legibility.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/db_surface_2" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#6fff3a" />
            <stroke android:width="2dp" android:color="@color/db_neon" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/db_neon_dim" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/db_neon" />
            <corners android:radius="10dp" />
        </shape>
    </item>

</selector>
