<?xml version="1.0" encoding="utf-8"?>
<!--
  Code-input background. Neutral border by default; brightens to
  neon green on focus so D-pad navigation has a clear "you are
  here" signal.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/db_surface_2" />
            <stroke android:width="2dp" android:color="@color/db_neon" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/db_surface_2" />
            <stroke android:width="1dp" android:color="@color/db_border" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</selector>
