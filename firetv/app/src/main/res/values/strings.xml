<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">DineroBook TV</string>
    <string name="app_brand_eyebrow">DINEROBOOK · TV DISPLAY</string>

    <!-- Pairing screen — TV-initiated flow.

         Operator's job is to read the code off the screen and type
         it into their admin browser. The TV doesn't accept input. -->
    <string name="pair_title">Set up this Fire TV</string>
    <string name="pair_subtitle">Sign in as an admin or employee, navigate to TV Display, type the code above.</string>

    <!-- "Open <baseUrl>/tv-display in your browser, then type
         this code." %1$s is BuildConfig.BASE_URL — defaults to
         https://dinerobook.onrender.com but can be overridden per
         build for staging. -->
    <string name="pair_where_to_enter">Open %1$s/tv-display in your DineroBook account.</string>

    <!-- Errors. The poll loop auto-recovers from most failures;
         this string only appears for total /init outages. -->
    <string name="pair_error_init">Couldn’t reach DineroBook. Retrying in a few seconds. (%1$s)</string>
</resources>
