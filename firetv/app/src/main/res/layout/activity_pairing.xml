<?xml version="1.0" encoding="utf-8"?>
<!--
  Pairing screen — TV-initiated flow.

  Layout intent: the SCREEN tells the operator what to do. Big
  brand mark up top, then the 6-character code rendered huge
  (visible from across the shop), then a single line of copy
  telling them WHERE to enter the code. No input on this screen
  at all — operators don't type 6 chars on a Fire TV remote.

  Vertically centered so a customer glancing at the TV during
  setup sees a clean intentional "this device is being set up"
  state rather than a half-formed UI.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/db_background"
    android:padding="48dp">

    <!-- Brand wordmark / eyebrow at the top. -->
    <TextView
        android:id="@+id/tvBrand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_brand_eyebrow"
        android:textColor="@color/db_text_muted"
        android:textSize="14sp"
        android:letterSpacing="0.18"
        android:fontFamily="sans-serif"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Title centered above the code -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/pair_title"
        android:textColor="@color/db_text_muted"
        android:textSize="20sp"
        android:gravity="center"
        android:fontFamily="sans-serif"
        app:layout_constraintBottom_toTopOf="@id/tvCode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- The big code. Vertically centered as a group with the
         where-to-enter copy below. JetBrains Mono via fontFamily
         so digits + letters share width — the code reads as 6
         distinct slots even at a distance. -->
    <TextView
        android:id="@+id/tvCode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:fontFamily="monospace"
        android:textSize="120sp"
        android:textStyle="bold"
        android:letterSpacing="0.18"
        android:textColor="@color/db_neon"
        android:text="------"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- "Open dinerobook.com/... and type this code there" -->
    <TextView
        android:id="@+id/tvBaseUrl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:textColor="@color/db_text"
        android:textSize="22sp"
        android:fontFamily="sans-serif"
        android:lineSpacingMultiplier="1.4"
        app:layout_constraintTop_toBottomOf="@id/tvCode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle under the where-to-enter line -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/pair_subtitle"
        android:textColor="@color/db_text_muted"
        android:textSize="16sp"
        android:fontFamily="sans-serif"
        app:layout_constraintTop_toBottomOf="@id/tvBaseUrl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Reserved error slot — only visible when init fails. The
         poll loop self-recovers, so this only appears for total
         network failures. -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:textColor="@color/db_error"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
