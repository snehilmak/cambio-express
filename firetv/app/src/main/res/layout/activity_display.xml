<?xml version="1.0" encoding="utf-8"?>
<!--
  Display screen — just a fullscreen WebView. Black background so
  the half-second between WebView paint and first frame doesn't
  flash white. The WebView itself loads the per-device URL the
  pair flow stashed in Prefs.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
